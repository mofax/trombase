	},
	"scripts": {
		"build": "vp pack",
		"prepublishOnly": "bun run build",
		"fmt": "oxfmt"
	},
	"dependencies": {
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/qs": "^6.15.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"bun-types": "^1.3.13",
		"qs": "^6.15.2",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"vite-plus": "^0.1.22"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
