{
	"name": "trombase",
	"version": "0.0.0",
	"description": "A simple backend for serverside JavaScript with PostgreSQL, schema DSL, and permission-checked DB access.",
	"homepage": "https://github.com/mofax/trombase#readme",
	"bugs": {
		"url": "https://github.com/mofax/trombase/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mofax/trombase.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"types": "./dist/main.d.mts",
	"exports": {
		".": {
			"types": "./dist/main.d.mts",
			"import": "./dist/main.mjs"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
